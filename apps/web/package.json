{
  "name": "web",
  "version": "1.1.0",
  "description": "Angular web application for Smart DMS.",
  "license": "AGPL-3.0-only",
  "author": "Pascal Bossert",
  "scripts": {
    "build": "ng build",
    "ng": "ng",
    "start": "ng serve",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:cov": "ng test --watch=false --coverage --coverage-reporters=text-summary --coverage-reporters=json-summary --coverage-exclude=src/app/app.routes.ts --coverage-exclude=src/app/app.config.ts --coverage-exclude=src/app/testing/** --coverage-exclude=src/environments/** --coverage-exclude=src/main.ts --coverage-exclude=src/app/core/api/api-base-url.token.ts --coverage-exclude=src/app/core/pdf/pdf-worker.provider.ts && node ../../scripts/check-coverage.mjs coverage/web/coverage-summary.json 70 69 70 72",
    "test:e2e": "node e2e/run-if-browser-available.mjs"
  },
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "dependencies": {
    "@angular/animations": "^21.2.15",
    "@angular/cdk": "^21.2.13",
    "@angular/common": "^21.2.15",
    "@angular/compiler": "^21.2.15",
    "@angular/core": "^21.2.15",
    "@angular/forms": "^21.2.15",
    "@angular/platform-browser": "^21.2.15",
    "@angular/router": "^21.2.15",
    "@ant-design/icons-angular": "21.0.0",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "@smart-dms/shared-dto": "file:../../packages/shared-dto",
    "ng-zorro-antd": "^21.3.0",
    "ng2-pdf-viewer": "10.4.0",
    "pdfjs-dist": "4.8.69",
    "rxjs": "~7.8.2",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.15",
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "jsdom": "^29.1.1",
    "less": "^4.6.4",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "vitest": "^4.1.7"
  }
