DATABASE_URL="postgresql://smart_dms:smart_dms@localhost:5432/smart_dms?schema=public"
PORT=3010
DMS_POSTGRES_DOCKER_IMAGE=postgres:16-alpine
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
DMS_SECRET_ENCRYPTION_KEY=replace-with-a-random-32-byte-secret
DMS_STORAGE_ROOT=./storage
DMS_SCANNER_IMPORT_DIR=./scanner-import
DMS_MAX_UPLOAD_SIZE_MB=100
DMS_OCR_DOCKER_IMAGE=smart-dms/ocr-runtime:latest
DMS_DOCLING_DOCKER_IMAGE=smart-dms/docling-runtime:latest
DMS_OCR_SERVICE_URL=
DMS_DOCLING_SERVICE_URL=
DMS_OCR_IMAGE_DPI=600
DMS_OCR_CLEAN=true
DMS_OCR_CLEAN_FINAL=false
DMS_OCR_OPTIMIZE=1
DMS_OCR_JOBS=2
DMS_OCR_TIMEOUT_MS=1800000
DMS_OCR_TESSERACT_TIMEOUT_SECONDS=30
DMS_OCR_TESSERACT_NON_OCR_TIMEOUT_SECONDS=10
DMS_OCR_STORAGE_CONTAINER_ROOT=/data
DMS_DOCLING_ENABLED=true
DMS_DOCLING_TIMEOUT_MS=600000
DMS_DOCLING_MAX_PAGES=200
DMS_DOCLING_MAX_FILE_SIZE_BYTES=104857600
DMS_DOCLING_DEBUG_JSON=false
DMS_THUMBNAIL_DPI=144
DMS_THUMBNAIL_JPEG_QUALITY=85
