# Local image build options used by docker compose build.
TESSDATA_BEST_REF=e12c65a915945e4c28e237a9b52bc4a8f39a0cec

# Published ports on the Docker host
SMART_DMS_WEB_PORT=8080
SMART_DMS_API_PORT=3010

# Traefik routing, used by docker-compose.traefik.yml.
# Helper scripts create SMART_DMS_TRAEFIK_NETWORK when it is missing.
SMART_DMS_TRAEFIK_HOST=dms.example.com
SMART_DMS_TRAEFIK_ENTRYPOINT=websecure
SMART_DMS_TRAEFIK_CERTRESOLVER=letsencrypt
SMART_DMS_TRAEFIK_NETWORK=proxy

# Docker networks
# By default Compose creates local bridge networks.
# Set SMART_DMS_BACKEND_NETWORK_EXTERNAL=true and SMART_DMS_BACKEND_NETWORK_NAME
# to attach the backend processes to an existing deployment/LAN network.
SMART_DMS_INTERNAL_NETWORK_NAME=smart-dms-internal
SMART_DMS_BACKEND_NETWORK_NAME=smart-dms-backend-egress
SMART_DMS_BACKEND_NETWORK_EXTERNAL=false

# PostgreSQL
SMART_DMS_POSTGRES_USER=smart_dms
SMART_DMS_POSTGRES_PASSWORD=replace-with-a-random-postgres-password
SMART_DMS_POSTGRES_DB=smart_dms

# Redis
# Leave empty to run Redis without a password.
SMART_DMS_REDIS_PASSWORD=replace-with-a-random-redis-password

# Backend security
JWT_ACCESS_SECRET=replace-with-a-random-secret
JWT_ACCESS_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
DMS_SECRET_ENCRYPTION_KEY=replace-with-a-random-32-byte-secret

# Storage and scanner import
# Storage uses the named Docker volume configured below.
SMART_DMS_SCANNER_IMPORT_PATH=./scanner-import
DMS_MAX_UPLOAD_SIZE_MB=100

# Optional: set SMART_DMS_SCANNER_IMPORT_GID to the host group ID that may read
# and move files from the scanner import path, then include
# docker-compose.scanner-group.yml when starting the stack.
SMART_DMS_SCANNER_IMPORT_GID=

# Persistent Docker volume names.
# Keep these values stable after the first production start.
SMART_DMS_POSTGRES_VOLUME_NAME=smart-dms_smart-dms-postgres-data
SMART_DMS_REDIS_VOLUME_NAME=smart-dms_smart-dms-redis-data
SMART_DMS_STORAGE_VOLUME_NAME=smart-dms_smart-dms-storage

# OCR and Docling sidecar runtimes
DMS_OCR_SERVICE_URL=http://ocr-runtime:8080
DMS_DOCLING_SERVICE_URL=http://docling-runtime:8080
DMS_OCR_IMAGE_DPI=600
DMS_OCR_CLEAN=true
DMS_OCR_CLEAN_FINAL=false
DMS_OCR_OPTIMIZE=1
DMS_OCR_JOBS=2
DMS_OCR_TIMEOUT_MS=1800000
DMS_OCR_TESSERACT_TIMEOUT_SECONDS=30
DMS_OCR_TESSERACT_NON_OCR_TIMEOUT_SECONDS=10
DMS_DOCLING_ENABLED=true
DMS_DOCLING_TIMEOUT_MS=600000
DMS_DOCLING_MAX_PAGES=200
DMS_DOCLING_MAX_FILE_SIZE_BYTES=104857600
DMS_DOCLING_DEBUG_JSON=false
DMS_THUMBNAIL_DPI=144
DMS_THUMBNAIL_JPEG_QUALITY=85
